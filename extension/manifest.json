{
  "manifest_version": 3,
  "name": "Invisible Addiction",
  "version": "2.0.0",
  "description": "Behavioral pattern detection for doom-scrolling apps.",
  "action": {
    "default_icon": {
      "16":  "icons/icon16.jpeg",
      "48":  "icons/icon48.jpeg",
      "128": "icons/icon128.jpeg"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "tabs", "notifications", "scripting"],
  "host_permissions": ["<all_urls>"]
}